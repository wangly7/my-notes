---
import "../styles/global.css";

const { title = "Interview Notes" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main class="container">
        <header style="margin-bottom: 32px;">
        <h1 style="margin-bottom: 4px;">My Notes</h1>
        <div class="meta">
            Problem solving · Patterns · Interview thinking
        </div>

        <nav style="margin-top: 12px; display: flex; gap: 14px; flex-wrap: wrap;">
            <a href="/">Home</a>
            <a href="/problems">Problems</a>
            <a href="/interview">Interview Notes</a>
            <a href="/projects">Projects</a>
            <a href="/concepts">Concepts</a>
            <a href="/snippets">Snippets</a>
        </nav>
        </header>

      <slot />
    </main>
  </body>
</html>